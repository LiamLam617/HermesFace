# HermesFace environment example
#
# HF Spaces:
#   Set these values as Repository Secrets.
#
# Local Docker:
#   cp .env.example .env
#   edit .env
#   docker run --env-file .env -v hermesface-data:/opt/data -p 7860:7860 hermesface


# Runtime mode:
#   agent             Start internal 9Router on port 20128 and Hermes dashboard on 7860.
#   ninerouter-setup  Start only the 9Router dashboard on port 7860 so you can configure providers.
HERMESFACE_MODE=agent


# 9Router dashboard/session settings.
# Set these before exposing HERMESFACE_MODE=ninerouter-setup on a public Space.
NINEROUTER_PASSWORD=
NINEROUTER_JWT_SECRET=


# Hermes uses the local 9Router OpenAI-compatible endpoint:
#   http://localhost:20128/v1
#
# Leave NINEROUTER_API_KEY=sk-local to keep agent-mode access local-only
# with REQUIRE_API_KEY=false. Set a real generated 9Router key if you want
# the internal endpoint to require API-key auth.
NINEROUTER_DEFAULT_MODEL=kr/claude-sonnet-4.5
NINEROUTER_API_KEY=sk-local


# Hermes Agent runtime.
AGENT_NAME=HermesFace
TZ=UTC


# Messaging platform secrets. Configure only the channels you use.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# DISCORD_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WEIXIN_APP_ID=xxxxxxxxxxxxxxxx
# WEIXIN_APP_SECRET=xxxxxxxxxxxxxxxx


# Optional provider keys can still be passed through for Hermes tools or
# other integrations, but Hermes chat traffic is routed through 9Router.
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOUS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_API_KEY=AIza...
# MISTRAL_API_KEY=mis-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# HF Spaces injects these automatically. They are shown here only for local
# debugging if you want to simulate Space metadata.
# SPACE_HOST=your-space.hf.space
# SPACE_ID=your-name/HermesFace
